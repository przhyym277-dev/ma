# ===== שרת =====
PORT=3000

# ===== סיסמת מנהל (להגנה על פאנל הניהול) =====
ADMIN_PASSWORD=Mahsan2026!

# ===== Cloudinary =====
# מתוך Dashboard → Account Details
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ===== Google Sheets =====
# מזהה הגיליון (החלק שבין /d/ ל-/edit בכתובת)
GOOGLE_SHEET_ID=your_sheet_id

# פרטי חשבון השירות (Service Account) מקובץ ה-JSON שהורדת מ-Google Cloud
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-bot@your-project.iam.gserviceaccount.com
# שימו לב: כל המפתח בשורה אחת, עם \n במקום ירידות שורה אמיתיות, בתוך מרכאות
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n...\n-----END PRIVATE KEY-----\n"
